//--------------------------------------------------------------------------------------------------
bool libB156CA28_gt_Countdown_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_sec;

    // Automatic Variable Declarations
    const int autoE5ABCD66_ae = 0;
    const int autoE5ABCD66_ai = -1;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    SoundPlayForPlayer(SoundLink("ModUtilityVoiceModUtilityVoice00106", -1), c_maxPlayers, libB156CA28_gv_playerObserverGroup, 100.0, 0.0);
    lv_sec = libB156CA28_gv_countdownDuration;
    for ( ; ( (autoE5ABCD66_ai >= 0 && lv_sec <= autoE5ABCD66_ae) || (autoE5ABCD66_ai < 0 && lv_sec >= autoE5ABCD66_ae) ) ; lv_sec += autoE5ABCD66_ai ) {
