// Triggers
//--------------------------------------------------------------------------------------------------
// Trigger: Untitled Trigger 001
//--------------------------------------------------------------------------------------------------
bool libB156CA28_gt_UntitledTrigger001_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    libB156CA28_gf_Default(1);
    return true;
}

//--------------------------------------------------------------------------------------------------
void libB156CA28_gt_UntitledTrigger001_Init () {
    libB156CA28_gt_UntitledTrigger001 = TriggerCreate("libB156CA28_gt_UntitledTrigger001_Func");
    TriggerAddEventMapInit(libB156CA28_gt_UntitledTrigger001);
}

void libB156CA28_InitTriggers () {
    libB156CA28_gt_UntitledTrigger001_Init();
}

//--------------------------------------------------------------------------------------------------
// Library Initialization
//--------------------------------------------------------------------------------------------------
bool libB156CA28_InitLib_completed = false;

void libB156CA28_InitLib () {
    if (libB156CA28_InitLib_completed) {
        return;
    }

    libB156CA28_InitLib_completed = true;

    libB156CA28_InitLibraries();
    libB156CA28_InitTriggers();
}

