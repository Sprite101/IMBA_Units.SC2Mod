    TechTreeUnitAllow(lp_player, "ReaperSwarm", false);
    TechTreeUnitAllow(lp_player, "SiegeTankLotV1", false);
    TechTreeUnitAllow(lp_player, "SiegeTankSiegedLotV1", false);
    TechTreeUnitAllow(lp_player, "WidowMineSwarm", false);
