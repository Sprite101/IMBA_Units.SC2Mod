        return true;
    }

    libB156CA28_gf_Hookups_PlayerFrames();
    libNtve_gf_SetDialogItemImage(libB156CA28_gv_playerFrames.lv_selectionPanel_BG[0], "Assets\\Textures\\ui_glues_scorescreen_racebg_zerg.dds", PlayerGroupAll());
    libNtve_gf_SetDialogItemImage(libB156CA28_gv_playerFrames.lv_selectionPanel_UnitInfo[0][2][0], "Assets\\Textures\\btn-building-terran-missileturret-silver.dds", PlayerGroupAll());
    libNtve_gf_SetDialogItemText(libB156CA28_gv_playerFrames.lv_selectionPanel_UnitInfo[0][2][1], StringExternal("Param/Value/lib_B156CA28_A7333CC3"), PlayerGroupAll());
    libNtve_gf_SetDialogItemImage(libB156CA28_gv_playerFrames.lv_selectionPanel_Unit_Selection[0][2][1][1], "Assets\\Textures\\btn-building-terran-missileturret-silver.dds", PlayerGroupAll());
    libNtve_gf_SetDialogItemText(libB156CA28_gv_playerFrames.lv_selectionPanel_Unit_Selection[0][2][1][2], StringExternal("Param/Value/lib_B156CA28_5CB86B76"), PlayerGroupAll());
    return true;
}

