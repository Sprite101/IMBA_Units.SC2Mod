    TechTreeUnitAllow(lp_player, "HellionSwarmBeta@Hellion", false);
    TechTreeUnitAllow(lp_player, "LiberatorAGLotV1@LiberatorAG", false);
    TechTreeUnitAllow(lp_player, "LiberatorLotV1@Liberator", false);
    TechTreeUnitAllow(lp_player, "RavenSwarm", false);
    TechTreeUnitAllow(lp_player, "ReaperLiberty", false);
    TechTreeUnitAllow(lp_player, "ReaperSwarm", false);
    TechTreeUnitAllow(lp_player, "SiegeTankLotV1", false);
    TechTreeUnitAllow(lp_player, "SiegeTankSiegedLotV1", false);
    TechTreeUnitAllow(lp_player, "WidowMineSwarm", false);
    TechTreeUnitAllow(lp_player, "WidowMineSwarm@WidowMineBurrowed", false);
    TechTreeUpgradeAllow(lp_player, "AdvancedBallistics", false);
    TechTreeUpgradeAllow(lp_player, "CorvidReactorSwarm", false);
    TechTreeUpgradeAllow(lp_player, "DurableMaterialsSwarm", false);
    TechTreeUpgradeAllow(lp_player, "EnhancedShockwaves@Upgrade", false);
    TechTreeUpgradeAllow(lp_player, "InfernalPreIgniterSwarm@InfernalPreIgniterSwarm", false);
    TechTreeUpgradeAllow(lp_player, "MoebiusReactor@Upgrade", false);
    TechTreeUpgradeAllow(lp_player, "ReaperLiberty@Upgrade", false);
    TechTreeUpgradeAllow(lp_player, "ReaperSwarm@Upgrade", false);
    TechTreeUpgradeAllow(lp_player, "CaduceusReactorSwarmBeta@CaduceusReactor", false);
    TechTreeUpgradeAllow(lp_player, "DrillingClaws@DrillingClaws", false);
    TechTreeUpgradeAllow(lp_player, "HurricaneThrusters@Upgrade", false);
    TechTreeUpgradeAllow(lp_player, "RapidFireLaunchers@Upgrade", false);
    TechTreeUpgradeAllow(lp_player, "ModifiedAbility@TerranVehicleAndShipWeaponsLevel1", false);
